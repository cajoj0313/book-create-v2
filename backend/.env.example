# ==================== 数据库配置 ====================
# MySQL 连接字符串格式：mysql+aiomysql://user:password@host:port/database
# 默认配置：lingbi 用户 / lingbi_password 密码 / localhost:3306 / lingbi 数据库
DATABASE_URL=mysql+aiomysql://lingbi:lingbi_password@localhost:3306/lingbi

# 存储类型：mysql 或 filesystem
# mysql: 使用 MySQL 数据库存储（推荐）
# filesystem: 使用 JSON 文件存储（开发测试用）
STORAGE_TYPE=mysql

# ==================== AI 配置 ====================
# 阿里百炼 API Key
# 获取地址：https://bailian.console.aliyun.com/
# 文档：https://help.aliyun.com/zh/dashscope/
DASHSCOPE_API_KEY=your_api_key_here

# ==================== 服务配置 ====================
# 后端服务端口（可选）
# 默认：8000
PORT=8000

# 调试模式（可选）
# true: 启用详细日志和热重载
# false: 生产环境
DEBUG=true

# ==================== 数据库初始化说明 ====================
# 1. 启动 MySQL: brew services start mysql@8.0
# 2. 创建数据库：mysql -u root -p -e "CREATE DATABASE lingbi CHARACTER SET utf8mb4;"
# 3. 执行建表：mysql -u root -p lingbi < scripts/create_tables.sql
# 4. 配置连接：编辑本文件，设置 DATABASE_URL
# 5. 安装依赖：pip install sqlalchemy[asyncio] aiomysql
# 详见：scripts/README.md